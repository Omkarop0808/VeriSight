# VeriSight AI - Environment Configuration Template
# Copy this file to .env and fill in the values

# --- API KEYS ---
# Get your Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- APP CONFIGURATION ---
# Optional: Set to 'production' or 'development'
DEBUG=False
PORT=8501

# --- MODEL PATHS ---
# Local checkpoints paths (if applicable)
CONVNEXT_CHECKPOINT=backend/checkpoints/convnextv2_base.pth
VIT_MODEL_NAME=dima806/ai_vs_real_image_detection
